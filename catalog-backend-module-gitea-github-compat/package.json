{
  "name": "@backstage/plugin-catalog-backend-module-gitea-github-compat",
  "version": "0.1.0-rhdh.1.10.1.1",
  "description": "Adapts explicitly selected GitHub-shaped catalog configuration and templates to Gitea",
  "backstage": {
    "role": "backend-plugin-module",
    "pluginId": "catalog",
    "pluginPackage": "@backstage/plugin-catalog-backend",
    "features": { ".": "@backstage/BackendFeature" }
  },
  "license": "Apache-2.0",
  "exports": { ".": "./src/index.ts", "./package.json": "./package.json" },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc && backstage-cli package build",
    "clean": "backstage-cli package clean",
    "test": "NODE_OPTIONS='--no-deprecation' backstage-cli package test --no-watch"
  },
  "dependencies": {
    "@backstage/catalog-model": "1.7.7",
    "@backstage/config": "1.3.6",
    "@backstage/errors": "1.2.7"
  },
  "peerDependencies": {
    "@backstage/backend-plugin-api": "~1.8.0",
    "@backstage/integration": "~2.0.0",
    "@backstage/plugin-catalog-node": "~2.1.0"
  },
  "devDependencies": {
    "@backstage/backend-plugin-api": "1.8.0",
    "@backstage/backend-test-utils": "1.11.1",
    "@backstage/cli": "0.36.0",
    "@backstage/cli-defaults": "0.1.0",
    "@backstage/integration": "2.0.0",
    "@backstage/plugin-catalog-node": "2.1.0",
    "@types/node": "22.13.14",
    "@jest/environment-jsdom-abstract": "30.3.0",
    "@types/jest": "30.0.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "jsdom": "27.4.0"
  }
}
