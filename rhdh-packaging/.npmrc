# .npmrc template — do NOT commit real tokens.
# The publish script generates a real .npmrc from ../.env at runtime.
# Set GITEA_NPM_SCOPE to your npm scope (e.g., nusun) in your .env file.
@${GITEA_NPM_SCOPE}:registry=${GITEA_BASE_URL}/api/packages/${GITEA_NPM_SCOPE}/npm/
//${GITEA_BASE_URL}:/_authToken=${GITEA_TOKEN}
